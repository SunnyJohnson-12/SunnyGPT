{
  "project": "lovable-chatgpt-clone",
  "services": {
    "frontend": {
      "type": "static",
      "directory": "aura-chat-main/dist",
      "build_command": "npm install && npm run build",
      "port": 3000
    },
    "backend": {
      "type": "node",
      "directory": "backend",
      "start_command": "npm install && npm start",
      "port": 5000,
      "env_files": [
        ".env"
      ]
    }
  }
}
